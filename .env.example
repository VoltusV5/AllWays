# ==========================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ==========================================
IS_PRODUCTION=False
DEBUG=True
SECRET_KEY=your_secret_key_here

# Хосты (через запятую без пробелов)
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ==========================================
# БАЗА ДАННЫХ (используется при IS_PRODUCTION=True)
# ==========================================
MYSQL_DB_NAME=your_db_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ==========================================
# ИНТЕГРАЦИИ (Яндекс.Расписания)
# ==========================================
YANDEX_SCHEDULE_API_KEY=your_yandex_api_key_here
YANDEX_SCHEDULE_BASE_URL=https://api.rasp.yandex.net/v3.0
YANDEX_REQUEST_TIMEOUT=30
YANDEX_MAX_RETRIES=3

# ==========================================
# ФРОНТЕНД И ДОПОЛНИТЕЛЬНО
# ==========================================
LOG_LEVEL=INFO
VUE_APP_API_URL=http://127.0.0.1:8000/api
